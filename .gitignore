# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
/node_modules/
.venv/
venv/

# ── Build Outputs ─────────────────────────────────────────────────────────────
dist/
/dist/
artifacts/
out/
*.tsbuildinfo

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]

# ── Secrets & Config ──────────────────────────────────────────────────────────
# .env.example is intentionally tracked (template only — no secrets).
# All populated .env files are excluded.
.env
.env.*

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log

# ── OS Noise ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Data Dirs (runtime, not source) ───────────────────────────────────────────
data/*
