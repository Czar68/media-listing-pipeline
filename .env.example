# Copy to .env and fill in. Never commit .env.
#
# EBAY_ENV=sandbox uses ONLY these keys (no EBAY_CLIENT_ID / EBAY_CLIENT_SECRET / EBAY_REFRESH_TOKEN):
#   EBAY_CLIENT_ID_SANDBOX
#   EBAY_CLIENT_SECRET_SANDBOX
#   EBAY_REFRESH_TOKEN_SANDBOX   (must start with v^1.1# — quote if value contains #)

EBAY_ENV=sandbox

EBAY_CLIENT_ID_SANDBOX=
EBAY_CLIENT_SECRET_SANDBOX=
EBAY_REFRESH_TOKEN_SANDBOX=

# Required for offer create + publish (Sell Inventory). Create via:
#   node scripts/create-merchant-location.js
EBAY_MERCHANT_LOCATION_KEY=

# eBay US leaf category for the offer (publish requires PrimaryCategory). Override per account.
EBAY_LISTING_CATEGORY_ID=111422

# Business policies (required for publish when sandbox uses fulfillment policies).
# Create in Seller Hub if GET /sell/account/v1/*_policy returns "not eligible".
EBAY_FULFILLMENT_POLICY_ID=
EBAY_PAYMENT_POLICY_ID=
EBAY_RETURN_POLICY_ID=

# Optional: bearer for scripts/ebay-policy-audit.js (must include sell.account scope). Often same as current EBAY_ACCESS_TOKEN after OAuth.
EBAY_APP_TOKEN=

EBAY_ACCESS_TOKEN=
EBAY_ACCESS_TOKEN_EXPIRES_AT=
