# Copy to .env and fill in. Never commit .env.
#
# EBAY_ENV=sandbox uses ONLY these keys (no EBAY_CLIENT_ID / EBAY_CLIENT_SECRET / EBAY_REFRESH_TOKEN):
#   EBAY_CLIENT_ID_SANDBOX
#   EBAY_CLIENT_SECRET_SANDBOX
#   EBAY_REFRESH_TOKEN_SANDBOX   (must start with v^1.1# — quote if value contains #)

EBAY_ENV=sandbox

EBAY_CLIENT_ID_SANDBOX=
EBAY_CLIENT_SECRET_SANDBOX=
EBAY_REFRESH_TOKEN_SANDBOX=

EBAY_ACCESS_TOKEN=
EBAY_ACCESS_TOKEN_EXPIRES_AT=
